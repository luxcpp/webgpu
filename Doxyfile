INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h *.hpp *.c *.cpp *.md
RECURSIVE              = YES

EXCLUDE                = build
EXCLUDE_SYMLINKS       = NO
EXCLUDE_PATTERNS       = */build/* */.git/* */third_party/*

EXAMPLE_PATH           = examples
